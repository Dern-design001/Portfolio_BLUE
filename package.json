{
  "name": "contact-app",
  "version": "1.0.0",
  "description": "Full-stack portfolio contact application",
  "main": "server.js",
  "scripts": {
    "start": "node server.js",
    "server": "nodemon server.js",
    "client:install": "npm install --prefix client",
    "client:build": "npm run build --prefix client",
    "client:dev": "npm run dev --prefix client",
    "dev": "concurrently \"npm run server\" \"npm run client:dev\"",
    "build": "npm run client:install && npm run client:build"
  },
  "dependencies": {
    "cors": "^2.8.5",
    "dotenv": "^16.3.1",
    "express": "^4.18.2",
    "mongoose": "^7.6.3"
  },
  "devDependencies": {
    "concurrently": "^9.2.1",
    "nodemon": "^3.0.1"
  }
}
